{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urielle-ai.com/schemas/agentic_assessment/evidence_decision.schema.json",
  "title": "Urielle-AI Clause 04 Evidence Decision",
  "description": "Governed evidence-assessment decision contract. Source evidence remains read-only and confidence is advisory only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "assessment_id",
    "question_id",
    "evidence_ids",
    "deterministic_checks",
    "semantic_observations",
    "decision",
    "human_review_required",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "decision_id": {
      "type": "string",
      "pattern": "^ED-[A-Z0-9][A-Z0-9._-]{2,99}$"
    },
    "assessment_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._-]{2,99}$"
    },
    "question_id": {
      "type": "string",
      "pattern": "^C4-Q[0-9]{2,3}$"
    },
    "evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200
      }
    },
    "deterministic_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/deterministicCheck"
      }
    },
    "semantic_observations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/semanticObservation"
      }
    },
    "decision": {
      "$ref": "#/$defs/evidenceDecision"
    },
    "confidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "human_review_required": {
      "type": "boolean"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "NOT_EVIDENCED"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "evidence_ids": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "enum": [
              "EVIDENCED",
              "PARTIALLY_EVIDENCED",
              "NOT_APPLICABLE"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "evidence_ids": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "enum": [
              "PARTIALLY_EVIDENCED",
              "REQUIRES_HUMAN_JUDGEMENT"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "human_review_required": {
            "const": true
          },
          "semantic_observations": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "evidenceDecision": {
      "type": "string",
      "enum": [
        "EVIDENCED",
        "PARTIALLY_EVIDENCED",
        "NOT_EVIDENCED",
        "NOT_APPLICABLE",
        "REQUIRES_HUMAN_JUDGEMENT"
      ]
    },
    "checkStatus": {
      "type": "string",
      "enum": [
        "PASSED",
        "FAILED",
        "NOT_RUN"
      ]
    },
    "deterministicCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "check_type",
        "status",
        "observation"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "pattern": "^CHK-[A-Z0-9][A-Z0-9._-]{1,99}$"
        },
        "check_type": {
          "type": "string",
          "enum": [
            "FILE_PRESENT",
            "OWNER_PRESENT",
            "DATE_PRESENT",
            "EVIDENCE_TYPE_VALID",
            "QUESTION_MAPPING_VALID",
            "HASH_VERIFIED"
          ]
        },
        "status": {
          "$ref": "#/$defs/checkStatus"
        },
        "observation": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    },
    "semanticObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observer_type",
        "observation"
      ],
      "properties": {
        "observer_type": {
          "type": "string",
          "enum": [
            "HUMAN",
            "DETERMINISTIC_RULES"
          ]
        },
        "observation": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "created_by",
        "generator",
        "generator_version",
        "source_refs"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "generator": {
          "type": "string",
          "enum": [
            "HUMAN",
            "DETERMINISTIC_RULES"
          ]
        },
        "generator_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      }
    }
  }
}
